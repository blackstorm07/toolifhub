# ======================================================
# ToolifHub — Environment Configuration
# Copy this file to .env.local and fill in your values.
# Only the 6 variables below need to be changed.
# ======================================================

# --- Database (MongoDB Atlas) ---
MONGODB_URI=YOUR_MONGODB_CONNECTION_STRING
DATABASE_NAME=toolifhub

# --- App ---
NEXT_PUBLIC_APP_NAME=ToolifHub
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Authentication ---
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS

# --- Admin Credentials (used by seed script to create the admin user) ---
ADMIN_EMAIL=admin@toolifhub.com
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# --- Google Tag Manager ---
# Loads GTM globally; configure GA4 and other tags inside your GTM container.
# Also add in Vercel → Project → Settings → Environment Variables for Production and Preview, then redeploy.
NEXT_PUBLIC_GTM_ID=

# --- Google Analytics 4 (optional reference) ---
# GA4 is managed via GTM — add your Measurement ID as a GA4 Configuration tag in GTM.
# Keep this for admin reference only; the app does not load gtag.js directly.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Twitter/X handle for Twitter Cards (optional) ---
NEXT_PUBLIC_TWITTER_HANDLE=@toolifhub

# --- Bing Webmaster Tools ownership verification (optional) ---
# Bing Webmaster Tools → Settings → Verify ownership → copy the content value
# from the meta tag option. Renders as <meta name="msvalidate.01">.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# --- Social profile URLs for Organization schema sameAs (optional, comma-separated) ---
NEXT_PUBLIC_SOCIAL_PROFILES=https://twitter.com/toolifhub,https://github.com/toolifhub

# --- Google AdSense (single adsbygoogle.js script in root layout via next/script) ---
# Also add in Vercel → Project → Settings → Environment Variables, then redeploy.
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Ad unit slot IDs (optional — defaults are baked into config/index.js)
NEXT_PUBLIC_GOOGLE_ADSENSE_HEADER_SLOT=2106750160
NEXT_PUBLIC_GOOGLE_ADSENSE_HOMEPAGE_SLOT=7660584898
NEXT_PUBLIC_GOOGLE_ADSENSE_TOOL_TOP_SLOT=3317593746
NEXT_PUBLIC_GOOGLE_ADSENSE_TOOL_MIDDLE_SLOT=8969797136
NEXT_PUBLIC_GOOGLE_ADSENSE_TOOL_BOTTOM_SLOT=5030552128
NEXT_PUBLIC_GOOGLE_ADSENSE_BLOG_TOP_SLOT=2404388781
NEXT_PUBLIC_GOOGLE_ADSENSE_BLOG_MIDDLE_SLOT=8081432898
NEXT_PUBLIC_GOOGLE_ADSENSE_CATEGORY_SLOT=4647408746
NEXT_PUBLIC_GOOGLE_ADSENSE_SIDEBAR_SLOT=8203510373
NEXT_PUBLIC_GOOGLE_ADSENSE_FOOTER_SLOT=9691430409

# --- SEO Tools: Third-Party Data Providers (optional) ---
# Tools backed by these keys show a "data provider not connected" state
# until the matching key below is set — they never fabricate data.
#
# SerpApi (or equivalent) — currently powers: Keyword Position Checker.
# (Google Index Checker / Search Snippet Preview Tool are planned for a
# later SEO tools batch and will also read this key once built.)
SERPAPI_KEY=
# Keyword-data API e.g. DataForSEO, Keywords Everywhere — currently powers:
# Search Volume Checker, Keyword Difficulty Checker.
# (Keyword Gap Analysis Tool is planned for a later batch.)
KEYWORDS_DATA_API_KEY=
# Moz Link Explorer API (or Ahrefs/Majestic) — NOT YET WIRED UP. Reserved for
# the Website Analysis Tools batch (Domain Authority/Page Authority/Backlink/
# Referring Domains checkers) — no tool reads this key yet.
MOZ_API_KEY=
# Google PageSpeed Insights API — NOT YET WIRED UP. Reserved for the
# Website Analysis Tools batch (Core Web Vitals Checker, Website Speed Test)
# — no tool reads this key yet.
PAGESPEED_API_KEY=

# --- Government Tools: data.gov.in AGMARKNET API (Mandi Price Checker) ---
# Register at https://data.gov.in/user/register → My Account → Generate API Key
# Dataset: Current Daily Price of Various Commodities from Various Markets (Mandi)
# Sector: Agriculture / Agricultural Marketing
DATA_GOV_IN_API_KEY=
DATA_GOV_IN_RESOURCE_ID=

# --- Groq (Llama 3.3 70B) ---
# Get a key at https://console.groq.com/keys
# Powers the AI Humanizer, AI Detector, AI Paraphraser, AI Summarizer, and
# AI Grammar Checker tools (app/api/ai/*). Server-side only — never exposed
# to the browser.
GROQ_API_KEY=
GROQ_MODEL=
